<section id="contact" class="section contact-section">
  <div class="panel" data-reveal="0">
    <p class="eyebrow eyebrow--light">CONTACT</p>
    <h2>Let's make your<br />model better.</h2>
    <p class="support">
      I'm in New York and open to Applied AI Engineer roles. Tell me what
      you're building.
    </p>
    <div class="ctas">
      <a class="pill pill--primary pill--contact" href="https://calendly.com/thitipun-snw/30min" target="_blank" rel="noopener">GRAB MY TIME →</a>
      <a class="pill pill--outline pill--contact-outline" href="https://www.linkedin.com/in/thitipun-s/" target="_blank" rel="noopener">LINKEDIN</a>
      <a class="pill pill--outline pill--contact-outline" href="/assets/Timo_Srinarmwong_Resume.pdf">RESUME (PDF)</a>
    </div>
  </div>
  <p class="colophon">© 2026 TIMO SRINARMWONG · NEW YORK, NY</p>
</section>

<style>
  .contact-section {
    padding-bottom: 64px;
  }

  .panel {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    padding: clamp(56px, 8vw, 88px) clamp(28px, 5vw, 64px);
    text-align: center;
    background:
      radial-gradient(55% 90% at 12% 8%, rgb(var(--rust-rgb) / 0.3), transparent 62%),
      radial-gradient(45% 80% at 92% 92%, rgb(var(--copper-rgb) / 0.24), transparent 65%),
      var(--panel);
    border: 1px solid rgb(var(--ink-rgb) / 0.08);
  }

  .eyebrow--light {
    color: var(--copper-light);
  }

  h2 {
    font-weight: 850;
    font-stretch: 110%;
    font-size: clamp(44px, 6.4vw, 76px);
    line-height: 0.96;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-top: 20px;
  }

  .support {
    font-size: 18px;
    line-height: 1.6;
    color: rgb(var(--ink-rgb) / 0.72);
    max-width: 46ch;
    margin: 22px auto 0;
  }

  .ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 16px;
    margin-top: 36px;
  }

  .pill--contact {
    font-size: 13px;
    padding: 18px 34px;
  }

  .pill--contact:hover {
    box-shadow: 0 18px 40px rgb(var(--rust-rgb) / 0.45);
  }

  .pill--contact-outline {
    font-size: 13px;
    padding: 16.5px 32px;
  }

  .colophon {
    text-align: center;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11.5px;
    letter-spacing: 0.1em;
    color: rgb(var(--ink-rgb) / 0.35);
    margin-top: 40px;
  }
</style>

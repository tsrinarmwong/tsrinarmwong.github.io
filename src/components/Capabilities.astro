---
const capabilities = [
  {
    number: '01',
    color: 'var(--rust)',
    title: 'MODEL QUALITY & EVALS',
    body: 'Rubrics, eval frameworks, adversarial test suites — turning "make it better" into something measurable.',
  },
  {
    number: '02',
    color: 'var(--copper)',
    title: 'FINE-TUNING & DATA',
    body: 'SFT/RLHF data pipelines, targeted curation, LoRA — quality-scored datasets that move human ratings.',
  },
  {
    number: '03',
    color: 'var(--copper-light)',
    title: 'AGENTS & TOOLING',
    body: 'Multi-step task design, tool-use evaluation, reproducible environments.',
  },
  {
    number: '04',
    color: 'var(--burnt)',
    title: 'SHIPPING',
    body: 'Python, PyTorch, SQL, Swift; Hugging Face, Fireworks.AI, Supabase, Firebase — end-to-end ownership.',
  },
];
---

<section id="capabilities" class="section">
  <div data-reveal="0">
    <p class="eyebrow eyebrow--copper">CAPABILITIES</p>
    <h2 class="section-title">How I work</h2>
  </div>
  <div class="cap-grid">
    <div class="cards">
      {
        capabilities.map((c, i) => (
          <article class="card" data-reveal={String(i)}>
            <div class="card-number" style={`color: ${c.color};`}>{c.number}</div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </article>
        ))
      }
    </div>
    <div class="terminal" data-reveal="1">
      <div class="terminal-header">
        <span class="dot" style="background: var(--burnt);"></span>
        <span class="dot" style="background: var(--copper);"></span>
        <span class="dot" style="background: var(--rust);"></span>
        <span class="terminal-title">timo@nyc — eval_loop.py</span>
        <span class="terminal-live">LIVE</span>
      </div>
      <div class="terminal-body" data-terminal></div>
      <div class="terminal-footer">
        <p>THE LOOP I RUN ON EVERY ENGAGEMENT — CURATE → TUNE → EVAL → SHIP</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Live eval-loop terminal: types a six-line loop, incrementing the
  // round counter each cycle. Renders statically under reduced motion.
  const host = document.querySelector<HTMLElement>('[data-terminal]');

  const SCRIPT = [
    { t: '$ python eval_loop.py --model prod --round {N}', cls: 'cmd' },
    { t: 'curating batch… 2,000+ examples quality-scored', cls: 'out' },
    { t: 'fine-tune round {N} complete · loss 0.41 → 0.28', cls: 'out' },
    { t: 'running evals across 6 domains…', cls: 'out' },
    { t: 'adversarial suite: 0 regressions found', cls: 'out' },
    { t: '✓ human-rated quality +84% — shipping', cls: 'ok' },
  ];
  const COLORS: Record<string, string> = {
    cmd: '#f2ece3',
    out: 'rgba(242,236,227,.62)',
    ok: '#d98e4f',
  };

  function makeLine(text: string, cls: string) {
    const div = document.createElement('div');
    div.style.color = COLORS[cls] || COLORS.out;
    if (cls === 'ok') div.style.fontWeight = '700';
    div.textContent = text;
    return div;
  }

  if (host && !host.dataset.booted) {
    host.dataset.booted = 'true';
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduced) {
      SCRIPT.forEach((l) => host.appendChild(makeLine(l.t.split('{N}').join('4'), l.cls)));
    } else {
      const caret = document.createElement('span');
      caret.textContent = '█';
      caret.style.color = '#c05621';
      caret.style.animation = 'ts-caret 1.1s step-end infinite';

      let round = 1;
      let li = 0;
      let ci = 0;
      let current: HTMLElement | null = null;

      function tick() {
        if (!host || !host.isConnected) return;
        if (li >= SCRIPT.length) {
          // Pause, then start the next round; trim old lines so the
          // terminal never grows unbounded.
          window.setTimeout(() => {
            if (host.children.length > 24) {
              while (host.children.length > 12) host.removeChild(host.firstChild!);
            }
            round += 1;
            li = 0;
            ci = 0;
            current = null;
            host.appendChild(document.createElement('br'));
            tick();
          }, 2600);
          return;
        }
        const line = SCRIPT[li];
        const full = line.t.split('{N}').join(String(round));
        if (!current) {
          current = makeLine('', line.cls);
          host.appendChild(current);
          current.appendChild(caret);
        }
        ci += line.cls === 'cmd' ? 1 : 3;
        const done = ci >= full.length;
        current.textContent = full.slice(0, ci);
        current.appendChild(caret);
        if (done) {
          current.textContent = full;
          li += 1;
          ci = 0;
          current = null;
          window.setTimeout(tick, li >= SCRIPT.length ? 200 : line.cls === 'cmd' ? 700 : 420);
        } else {
          window.setTimeout(tick, line.cls === 'cmd' ? 34 : 14);
        }
      }
      tick();
    }
  }
</script>

<style>
  .eyebrow--copper {
    color: var(--copper);
  }

  .cap-grid {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 6fr);
    gap: clamp(24px, 3vw, 40px);
    align-items: stretch;
    margin-top: 48px;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .card {
    background: var(--card);
    border: 1px solid rgb(var(--ink-rgb) / 0.08);
    border-radius: 18px;
    padding: 26px 24px;
    transition:
      transform 200ms ease,
      box-shadow 200ms ease,
      border-color 200ms ease;
  }

  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 44px rgb(0 0 0 / 0.4);
    border-color: rgb(var(--rust-rgb) / 0.45);
  }

  .card-number {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 24px;
  }

  .card h3 {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--ink);
    margin-top: 16px;
  }

  .card p {
    font-size: 14px;
    line-height: 1.6;
    color: rgb(var(--ink-rgb) / 0.62);
    margin-top: 10px;
  }

  .terminal {
    display: flex;
    flex-direction: column;
    background: var(--term-bg);
    border: 1px solid rgb(var(--ink-rgb) / 0.1);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 24px 56px rgb(0 0 0 / 0.45);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--term-header);
    border-bottom: 1px solid rgb(var(--ink-rgb) / 0.08);
    padding: 13px 18px;
  }

  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }

  .terminal-title {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 11.5px;
    letter-spacing: 0.12em;
    color: rgb(var(--ink-rgb) / 0.5);
    margin-left: 10px;
  }

  .terminal-live {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 10.5px;
    letter-spacing: 0.16em;
    color: var(--copper-light);
    margin-left: auto;
  }

  .terminal-body {
    flex: 1;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 13.5px;
    line-height: 2.05;
    color: rgb(var(--ink-rgb) / 0.78);
    padding: 22px 24px;
    min-height: 320px;
  }

  .terminal-footer {
    border-top: 1px solid rgb(var(--ink-rgb) / 0.08);
    padding: 12px 18px;
  }

  .terminal-footer p {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    color: rgb(var(--ink-rgb) / 0.35);
  }

  @media (max-width: 820px) {
    .cap-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }
</style>

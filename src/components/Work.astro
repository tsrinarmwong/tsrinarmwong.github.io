---
import LogoSlot from './LogoSlot.astro';
import metaLogo from '../assets/logos/meta.png';
import mercorLogo from '../assets/logos/mercor.png';
import snorkelLogo from '../assets/logos/snorkel.jpg';

const cases = [
  {
    client: '01 · META',
    initial: 'M',
    logo: metaLogo,
    flip: false,
    accents: `--pill-bg: rgb(var(--rust-rgb) / 0.14); --pill-border: rgb(var(--rust-rgb) / 0.3); --quote-border: var(--rust); --panel-hover-border: rgb(var(--rust-rgb) / 0.4);`,
    title: "Teaching Meta's production LLM to speak Thai",
    body: "Meta's production LLM underperformed in Thai — a low-resource language where generic multilingual data falls short. I paired native-speaker judgment with rubric-driven eval loops and targeted curation: 2,000+ quality-scored examples feeding every fine-tune round.",
    quote: '"Curation beats volume when the evaluator speaks the language."',
    meta: 'AI ENGINEER (CONTRACT) · OCT 2024 – JUN 2025 · PYTHON, PYTORCH, FINE-TUNING & EVAL PIPELINES',
    results: [
      { label: 'Human-rated output quality', value: '~+84%', kind: 'lg' },
      { label: 'Curated training examples', value: '2,000+', kind: 'md' },
      { label: 'Outcome', value: 'shipped production gains', kind: 'text', maxWidth: '55%' },
    ],
  },
  {
    client: '02 · MERCOR',
    initial: 'M',
    logo: mercorLogo,
    flip: true,
    accents: `--pill-bg: rgb(var(--copper-rgb) / 0.14); --pill-border: rgb(var(--copper-rgb) / 0.35); --quote-border: var(--copper); --panel-hover-border: rgb(var(--copper-rgb) / 0.45);`,
    title: 'Stress-testing models for three frontier labs',
    body: 'Three frontier research labs needed to know exactly where their models fail — before users did. I built cross-domain evaluation frameworks and adversarial edge-case suites across coding, chemistry, cybersecurity, data analysis, reasoning, and applied AI, feeding RLHF and SFT alignment pipelines.',
    quote: '"A model is only as good as the hardest question you ask it."',
    meta: 'AI ENGINEER (CONTRACT) · JUN 2025 – JUN 2026 · PYTHON, EVAL DESIGN, RLHF/SFT PIPELINES',
    results: [
      { label: 'Model accuracy across cycles', value: '+72%', kind: 'lg' },
      { label: 'Scope', value: '3 labs · 5 projects · 6 domains', kind: 'text' },
      { label: 'Hallucination on production outputs', value: 'measurably reduced', kind: 'text', maxWidth: '45%' },
    ],
  },
  {
    client: '03 · SNORKEL AI',
    initial: 'S',
    logo: snorkelLogo,
    flip: false,
    accents: `--pill-bg: rgb(var(--burnt-rgb) / 0.16); --pill-border: rgb(var(--burnt-rgb) / 0.4); --quote-border: var(--burnt); --panel-hover-border: rgb(var(--burnt-rgb) / 0.5);`,
    title: 'Building the gyms where coding agents train',
    body: 'Flaky environments poison training data. I designed multi-step coding-agent tasks that force genuine end-to-end reasoning, then treated the environments themselves as production software — debugged, hardened, verified with full test suites.',
    quote: '"Agent quality starts with environment quality."',
    meta: 'AI ENGINEER (CONTRACT) · JAN 2026 – MAY 2026 · PYTHON, AGENT TASK DESIGN, TEST SUITES',
    results: [
      { label: 'Flaky / failed agent runs', value: '~−30%', kind: 'lg' },
      { label: 'Verified solutions w/ test suites', value: '50+', kind: 'md' },
      { label: 'Task environments hardened', value: '15+', kind: 'md' },
    ],
  },
];
---

<section id="work" class="section">
  <div data-reveal="0">
    <p class="eyebrow">CASE STUDIES</p>
    <h2 class="section-title">Selected work</h2>
  </div>

  {
    cases.map((c, i) => (
      <article
        class:list={['case', { 'case--flip': c.flip, 'case--first': i === 0, 'case--last': i === cases.length - 1 }]}
        data-reveal="0"
        style={c.accents}
      >
        <div class="case-text">
          <div class="case-header">
            <LogoSlot size={56} radius={14} initial={c.initial} image={c.logo} />
            <span class="client-pill">{c.client}</span>
          </div>
          <h3>{c.title}</h3>
          <p class="case-body">{c.body}</p>
          <p class="takeaway">{c.quote}</p>
          <p class="case-meta">{c.meta}</p>
        </div>
        <div class="results">
          <div class="results-label">RESULTS</div>
          {c.results.map((r) => (
            <div class="result-row">
              <span class="result-name">{r.label}</span>
              <span
                class:list={['result-value', `result-value--${r.kind}`]}
                style={r.maxWidth ? `max-width: ${r.maxWidth};` : undefined}
              >
                {r.value}
              </span>
            </div>
          ))}
        </div>
      </article>
    ))
  }
</section>

<style>
  .case {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: clamp(32px, 4.5vw, 56px);
    align-items: start;
    border-top: 1px solid rgb(var(--ink-rgb) / 0.12);
    padding: 56px 0;
  }

  .case--first {
    margin-top: 56px;
  }

  .case--last {
    border-bottom: 1px solid rgb(var(--ink-rgb) / 0.12);
  }

  .case--flip {
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
  }

  .case--flip .case-text {
    order: 2;
  }

  .case--flip .results {
    order: 1;
  }

  .case-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .client-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.18em;
    color: var(--copper-light);
    background: var(--pill-bg);
    border: 1px solid var(--pill-border);
    border-radius: 999px;
    padding: 8px 16px;
  }

  h3 {
    font-weight: 800;
    font-size: clamp(28px, 3.3vw, 40px);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin-top: 22px;
    max-width: 24ch;
  }

  .case-body {
    font-size: 16px;
    line-height: 1.7;
    color: rgb(var(--ink-rgb) / 0.72);
    margin-top: 20px;
    max-width: 58ch;
  }

  .takeaway {
    font-size: 19px;
    line-height: 1.5;
    font-weight: 600;
    font-style: italic;
    color: var(--copper-light);
    border-left: 2px solid var(--quote-border);
    padding-left: 18px;
    margin-top: 26px;
  }

  .case-meta {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11.5px;
    letter-spacing: 0.1em;
    line-height: 1.8;
    color: rgb(var(--ink-rgb) / 0.45);
    margin-top: 24px;
  }

  .results {
    background: var(--panel);
    border: 1px solid rgb(var(--ink-rgb) / 0.08);
    border-radius: 20px;
    padding: 30px 32px;
    transition:
      transform 200ms ease,
      box-shadow 200ms ease,
      border-color 200ms ease;
  }

  .results:hover {
    transform: translateY(-4px);
    box-shadow: 0 22px 48px rgb(0 0 0 / 0.45);
    border-color: var(--panel-hover-border);
  }

  .results-label {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.24em;
    color: var(--copper-light);
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 18px;
    border-top: 1px solid rgb(var(--ink-rgb) / 0.1);
    padding: 14px 0;
  }

  .result-row:first-of-type {
    border-top: 0;
    padding: 16px 0 14px;
  }

  .result-row:last-of-type {
    padding-bottom: 0;
  }

  .result-name {
    font-size: 14.5px;
    color: rgb(var(--ink-rgb) / 0.66);
  }

  .result-value {
    font-family: var(--font-mono);
    text-align: right;
  }

  .result-value--lg {
    font-weight: 700;
    font-size: 32px;
    color: var(--copper-light);
  }

  .result-value--md {
    font-weight: 700;
    font-size: 22px;
    color: var(--ink);
  }

  .result-value--text {
    font-weight: 600;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink);
  }

  @media (max-width: 820px) {
    .case,
    .case--flip {
      grid-template-columns: 1fr;
    }

    /* Results panel always reads after the narrative on small screens. */
    .case--flip .case-text {
      order: 1;
    }

    .case--flip .results {
      order: 2;
    }
  }
</style>

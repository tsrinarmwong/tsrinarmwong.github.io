---
import { Image } from 'astro:assets';
import LogoSlot from './LogoSlot.astro';
import profile from '../assets/profile.jpg';
---

<section id="about" class="section">
  <div class="about-grid">
    <div class="photo-wrap" data-reveal="0">
      <div class="accent-block" aria-hidden="true" data-drift></div>
      <Image
        class="photo"
        src={profile}
        alt="Timo Srinarmwong on a rooftop terrace with a city skyline behind him"
        widths={[480, 720, 1000]}
        sizes="(max-width: 820px) 100vw, 40vw"
      />
    </div>
    <div data-reveal="1">
      <p class="eyebrow">ABOUT — NEW YORK, NY</p>
      <h2>Language nerd turned model whisperer</h2>
      <p class="bio">
        I started in communications, got obsessed with what makes language
        work, and ended up with a CS master's from Illinois Tech — teaching
        machines to use it better. Along the way I shipped a solo consumer iOS
        app to ~15K downloads with zero paid acquisition, and made the call to
        sunset it when the retention data said so. I like ambiguous problems,
        honest metrics, and shipping.
      </p>
      <div class="goldi-chip">
        <LogoSlot size={52} radius={12} initial="G" />
        <div>
          <span class="goldi-name">GOLDI</span>
          <span class="goldi-desc">bill-splitting iOS app · solo design/build/ship · SwiftUI + Firebase · ~15K downloads, zero paid acquisition</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: clamp(36px, 5vw, 64px);
    align-items: center;
  }

  .photo-wrap {
    position: relative;
  }

  .accent-block {
    position: absolute;
    inset: -18px -18px auto auto;
    width: 60%;
    height: 60%;
    background: linear-gradient(135deg, var(--burnt), var(--rust));
    border-radius: 20px;
    animation: ts-drift 7s ease-in-out infinite alternate;
  }

  .photo {
    position: relative;
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 20px;
    filter: saturate(0.92) contrast(1.04);
    box-shadow: 0 28px 64px rgb(0 0 0 / 0.55);
    transition: transform 250ms ease;
  }

  .photo:hover {
    transform: rotate(-1.2deg) scale(1.01);
  }

  h2 {
    font-weight: 850;
    font-stretch: 108%;
    font-size: clamp(36px, 4.6vw, 56px);
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    margin-top: 16px;
  }

  .bio {
    font-size: 17px;
    line-height: 1.7;
    color: rgb(var(--ink-rgb) / 0.75);
    margin-top: 24px;
    max-width: 60ch;
  }

  .goldi-chip {
    display: flex;
    align-items: center;
    gap: 18px;
    background: var(--panel);
    border: 1px solid rgb(var(--ink-rgb) / 0.08);
    border-radius: 16px;
    padding: 16px 22px;
    margin-top: 30px;
    transition:
      transform 200ms ease,
      border-color 200ms ease;
  }

  .goldi-chip:hover {
    transform: translateY(-3px);
    border-color: rgb(217 142 79 / 0.4);
  }

  .goldi-name {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.12em;
    color: var(--copper-light);
  }

  .goldi-desc {
    display: block;
    font-size: 13.5px;
    line-height: 1.6;
    color: rgb(var(--ink-rgb) / 0.62);
    margin-top: 4px;
  }

  @media (max-width: 820px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Work from '../components/Work.astro';
import Capabilities from '../components/Capabilities.astro';
import About from '../components/About.astro';
import Certifications from '../components/Certifications.astro';
import Contact from '../components/Contact.astro';
---

<Base
  title="Timo Srinarmwong — Applied AI Engineer"
  description="Applied AI engineer in NYC. Fine-tuning, evaluation frameworks, and agent pipelines on frontier-model programs at Meta, Snorkel AI, and three frontier labs."
>
  <Hero />
  <main id="main">
    <Work />
    <Capabilities />
    <About />
    <Certifications />
    <Contact />
  </main>
</Base>

<script>
  // Scroll-triggered staggered reveals. Hidden state is applied from JS,
  // so without JS (or with reduced motion) everything renders at rest.
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const els = [...document.querySelectorAll<HTMLElement>('[data-reveal]')];

  if (!reduced && 'IntersectionObserver' in window && els.length) {
    const DURATION = 530; // ms
    const STAGGER = 96; // ms per data-reveal step
    const OFFSET = 24; // px
    const EASE = 'cubic-bezier(.22,1,.36,1)';
    const revealed = new WeakSet<HTMLElement>();

    function show(el: HTMLElement) {
      if (revealed.has(el)) return;
      revealed.add(el);
      const step = parseInt(el.getAttribute('data-reveal') ?? '0', 10) || 0;
      const delay = step * STAGGER;
      el.style.transition = `opacity ${DURATION}ms ${EASE} ${delay}ms, transform ${DURATION}ms ${EASE} ${delay}ms`;
      requestAnimationFrame(() => {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0px)';
      });
    }

    const vh = window.innerHeight || document.documentElement.clientHeight;
    const pending: HTMLElement[] = [];
    els.forEach((el) => {
      const r = el.getBoundingClientRect();
      el.style.opacity = '0';
      el.style.transform = `translateY(${OFFSET}px)`;
      // Elements already in view animate in immediately.
      if (r.top < vh * 0.94 && r.bottom > 0) {
        show(el);
      } else {
        pending.push(el);
      }
    });

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((en) => {
          if (!en.isIntersecting) return;
          show(en.target as HTMLElement);
          io.unobserve(en.target);
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -4% 0px' }
    );
    pending.forEach((el) => io.observe(el));

    // Failsafe: nothing stays hidden if the observer never fires.
    window.setTimeout(() => pending.forEach(show), 4000);
  }
</script>

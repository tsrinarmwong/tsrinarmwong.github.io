---
import Base from '../layouts/Base.astro';

// Copy here sticks to facts already on the site; the .art panels are
// placeholders — swap each for a real screenshot, diagram, or photo:
//   <img src="/images/….png" alt="…" />
const projects = [
  {
    slug: 'thai-llm-meta',
    title: 'Fine-tuning Meta’s production LLM for Thai',
    meta: 'Meta · 2024–2025',
    result: 'Human-rated output quality up ~84%',
    body: 'I fine-tuned Meta’s production LLM for Thai, my native language, so the evaluation could not hide from me. The work was rubrics, datasets, and test harnesses more than modeling: turning “make the model better” into something measurable, then iterating against it.',
    art: '--art-a: var(--pastel-rose); --art-b: var(--pastel-cream); --art-c: var(--pastel-lilac);',
  },
  {
    slug: 'frontier-evals-mercor',
    title: 'Evaluating frontier models across six domains',
    meta: 'Three frontier labs, via Mercor · 2025–2026',
    result: 'Accuracy up 72% across iteration cycles',
    body: 'Evaluation programs for three frontier labs, run through Mercor, covering six domains. The job was building evals that hold up under adversarial prompts, then using them to drive iteration cycles.',
    art: '--art-a: var(--pastel-sky); --art-b: var(--pastel-lilac); --art-c: var(--pastel-cream);',
  },
  {
    slug: 'coding-agents-snorkel',
    title: 'Training coding agents to reason end-to-end',
    meta: 'Snorkel AI · 2026',
    result: 'Flaky agent runs down ~30%',
    body: 'At Snorkel AI I worked on training data and evaluation for coding agents, with the goal of getting them to reason end-to-end instead of failing intermittently partway through a task.',
    art: '--art-a: var(--pastel-lilac); --art-b: var(--pastel-rose); --art-c: var(--pastel-sky);',
  },
  {
    slug: 'goldi',
    title: 'GOLDI: shipping and sunsetting a solo iOS app',
    meta: 'Independent · 2024–2025',
    result: '15K downloads, zero paid acquisition, deliberate shutdown',
    body: 'A solo iOS app I built and shipped to roughly 15,000 downloads with zero paid acquisition. Eleven months later the retention data said to stop, so I shut it down on purpose. Reading the numbers before trusting the demo applies to my own products too.',
    art: '--art-a: var(--pastel-cream); --art-b: var(--pastel-sky); --art-c: var(--pastel-rose);',
  },
];
---

<Base
  title="Work — Timo Srinarmwong"
  description="Selected applied AI work: fine-tuning Meta’s production LLM for Thai, frontier-model evals via Mercor, coding agents at Snorkel AI, and a solo iOS app."
>
  <section class="work-intro">
    <h1>Work</h1>
    <p>
      Four projects, each with a number attached. Full write-ups are in
      progress; the short versions are below.
    </p>
  </section>

  {
    projects.map((p, i) => (
      <article class="project" id={p.slug}>
        <p class="meta">
          {String(i + 1).padStart(2, '0')} · {p.meta}
        </p>
        <h2>{p.title}</h2>
        <figure class="frame">
          <div class="art project-art" style={p.art} />
          <figcaption class="meta">{p.result}</figcaption>
        </figure>
        <p>{p.body}</p>
      </article>
    ))
  }
</Base>

<style>
  .work-intro {
    padding-block: 4rem 0;
  }

  .work-intro p {
    margin-top: 1rem;
    color: var(--ink-muted);
  }

  .project {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--rule);
    /* Anchor targets land below the header. */
    scroll-margin-top: 2rem;
  }

  .project h2 {
    margin-block: 0.5rem 1.5rem;
  }

  .project-art {
    aspect-ratio: 5 / 2;
  }

  .project figure {
    margin-bottom: 1.5rem;
  }
</style>
